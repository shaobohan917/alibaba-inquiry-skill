# Alibaba 询盘自动化工具配置

# 大模型 API 配置
LLM_BASE_URL=https://api.anthropic.com
LLM_API_KEY=your_api_key_here
LLM_MODEL=claude-sonnet-4-5-20250929

# 回复配置
REPLY_LANGUAGE=auto
# auto = 根据客户消息语言自动匹配
# 或指定固定语言：en, zh, es, fr, etc.

# 操作延迟配置 (毫秒)
DELAY_BETWEEN_ACTIONS_MIN=3000
DELAY_BETWEEN_ACTIONS_MAX=8000

# 询盘列表页 URL
ALIBABA_MESSAGE_URL=https://message.alibaba.com/message/default.htm?spm=a2756.trade-list-seller.0.0.79e8601aewBszG#feedback/all
