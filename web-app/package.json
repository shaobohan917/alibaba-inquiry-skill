{
  "name": "ali-ai-agent-system",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "阿里国际站 AI 智能体协同系统 企业级桌面前端",
  "scripts": {
    "dev": "vite",
    "test": "vitest",
    "backend:init": "node backend/scripts/init-db.js",
    "backend:dev": "node --watch backend/src/server.js",
    "backend:start": "node backend/src/server.js",
    "build": "tsc -b && vite build",
    "prepare:backend-bundle": "node scripts/prepare-backend-bundle.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:desktop": "tauri build",
    "build:mac": "tauri build --bundles dmg",
    "build:windows": "tauri build --bundles nsis,msi",
    "build:linux": "tauri build --bundles appimage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@tauri-apps/api": "^2.5.0",
    "antd": "^5.26.0",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.6.0",
    "recharts": "^2.15.3",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.3.5",
    "vitest": "^4.1.4"
  }
}
