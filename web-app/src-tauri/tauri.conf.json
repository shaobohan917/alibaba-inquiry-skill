{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "阿里国际站 AI 智能体协同系统",
  "version": "2.0.0",
  "identifier": "com.opc.ali-ai-agent-system",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run prepare:backend-bundle",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "阿里国际站 AI 智能体协同系统",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 760,
        "center": true,
        "resizable": true,
        "maximized": false,
        "fullscreen": false,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/backend-runtime.tar.gz": "backend-runtime.tar.gz"
    },
    "publisher": "OPC",
    "category": "Business",
    "shortDescription": "阿里国际站 AI 智能体协同系统 - 企业级桌面应用",
    "longDescription": "阿里国际站 AI 智能体协同系统是面向阿里国际站业务流程的企业级桌面应用，使用 Vite、React、TypeScript 与 Tauri v2 构建。包含 7 大 AI Agent：业务员、运营、采购、库存、物流、设计、主管。",
    "copyright": "Copyright (c) 2026 OPC. All rights reserved.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
